# Postgres — Vercel Marketplace / Neon in production; docker-compose for local dev
DATABASE_URL=postgres://gloria:gloria@localhost:5432/gloria_dev

# Separate database used by content-repository integration tests
TEST_DATABASE_URL=postgres://gloria:gloria@localhost:5432/gloria_test

# Seed admin user (used by scripts/seed.ts only)
SEED_ADMIN_EMAIL=admin@gloriahmutheu.com
SEED_ADMIN_PASSWORD=change-me

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32-char-secret

# Paystack (https://dashboard.paystack.com/#/settings/developers)
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_WEBHOOK_SECRET=...

# Canonical base URL (used by checkout callback URL)
NEXT_PUBLIC_BASE_URL=https://gloriahmutheu.com

# Vercel Blob — set via Vercel dashboard → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Resend (https://resend.com) — transactional email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@gloriahmutheu.com
